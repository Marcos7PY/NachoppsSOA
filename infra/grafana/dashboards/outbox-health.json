{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 38,
  "title": "NachoPps — Salud del Outbox",
  "uid": "nachopps-outbox",
  "tags": ["nachopps", "outbox", "event-driven"],
  "time": { "from": "now-3h", "to": "now" },
  "refresh": "10s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Outbox pendientes por servicio",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "short" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "max by (service) (outbox_pending_total)",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Outbox FAILED por servicio (dead-letter en BD)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 20 },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "max by (service) (outbox_failed_total)",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Total pendientes (todos los servicios)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "expr": "sum(outbox_pending_total)", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "title": "Total FAILED (todos los servicios)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 9 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        { "expr": "sum(outbox_failed_total)", "refId": "A" }
      ]
    }
  ]
}
