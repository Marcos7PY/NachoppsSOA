{
  "name": "@org/servicio-cuentas",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "name": "servicio-cuentas",
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "outputs": [
          "{workspaceRoot}/dist/apps/servicio-cuentas"
        ],
        "options": {
          "command": "tsc -p apps/servicio-cuentas/tsconfig.app.json && npx tsc-alias -p apps/servicio-cuentas/tsconfig.app.json && node -e \"const fs=require('fs'); if(fs.existsSync('apps/servicio-cuentas/src/generated')) fs.cpSync('apps/servicio-cuentas/src/generated', 'dist/apps/servicio-cuentas/apps/servicio-cuentas/src/generated', {recursive: true})\""
        },
        "configurations": {
          "production": {},
          "development": {}
        }
      },
      "serve": {
        "executor": "nx:run-commands",
        "dependsOn": [
          "build"
        ],
        "options": {
          "command": "node dist/apps/servicio-cuentas/apps/servicio-cuentas/src/main.js"
        },
        "continuous": true
      }
    },
    "tags": [
      "backend",
      "service",
      "cuentas"
    ]
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "tslib": "^2.3.0",
    "@org/resiliencia": "*",
    "@org/contracts": "*",
    "@org/shared-rabbitmq": "*",
    "@org/observabilidad": "*",
    "@org/shared-auth": "*"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.0.0"
  }
}
