generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  output          = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Transaccion {
  id          String   @id @default(uuid())
  cuentaId    String
  turnoId     String?
  mesaId      String?
  monto       Decimal  @db.Decimal(10, 2)
  descuento   Decimal  @default(0) @db.Decimal(10, 2)
  metodo      String   // EFECTIVO, TARJETA, etc.
  referencia  String?
  notas       String?
  createdAt   DateTime @default(now())

  turno       TurnoCaja? @relation(fields: [turnoId], references: [id])

  @@index([cuentaId])
  @@index([turnoId])
  @@map("transacciones")
}

model OutboxEvent {
  id         String   @id @default(uuid())
  routingKey String
  payload    String
  status     String   @default("PENDING") // PENDING, PROCESSED, FAILED
  attempts   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([status, createdAt])
  @@map("outbox_events")
}

// Idempotencia HTTP (plan 1.3): persiste la Idempotency-Key y la respuesta para
// hacer *replay* en reintentos de POST /caja/pagos (evita pagos duplicados).
model IdempotencyKey {
  id          String    @id @default(uuid())
  key         String    @unique
  method      String?
  path        String?
  statusCode  Int?
  body        String?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([createdAt])
  @@map("idempotency_keys")
}

model CierreCaja {
  id           String   @id @default(uuid())
  turnoId      String?  @unique
  montoEsperado Decimal  @db.Decimal(10, 2)
  montoReal     Decimal  @db.Decimal(10, 2)
  diferencia    Decimal  @db.Decimal(10, 2)
  usuarioId     String
  resumen       Json?
  createdAt     DateTime @default(now())

  turno         TurnoCaja? @relation(fields: [turnoId], references: [id])

  @@map("cierres_caja")
}

model CuentaAbierta {
  cuentaId String   @id
  mesaId   String
  total    Decimal  @db.Decimal(10, 2)
  estado   String

  @@map("cuentas_abiertas")
}

model TurnoCaja {
  id            String   @id @default(uuid())
  cajaId        String
  cajaNombre    String
  usuarioId     String
  cajeroNombre  String?
  fondoInicial  Decimal  @db.Decimal(10, 2)
  estado        String
  abiertoAt     DateTime @default(now())
  cerradoAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  transacciones Transaccion[]
  movimientos   MovimientoCaja[]
  arqueos       ArqueoCaja[]
  cierre        CierreCaja?

  @@index([estado, abiertoAt])
  @@index([usuarioId, estado])
  @@map("turnos_caja")
}

model MovimientoCaja {
  id            String   @id @default(uuid())
  turnoId       String
  tipo          String
  cuentaId      String?
  transaccionId String?
  mesaId        String?
  donde         String
  metodo        String
  monto         Decimal  @db.Decimal(10, 2)
  descuento     Decimal  @default(0) @db.Decimal(10, 2)
  propina       Decimal  @default(0) @db.Decimal(10, 2)
  motivo        String?
  createdAt     DateTime @default(now())

  turno         TurnoCaja @relation(fields: [turnoId], references: [id])

  @@index([turnoId, createdAt])
  @@index([cuentaId])
  @@unique([transaccionId])
  @@map("movimientos_caja")
}

model ArqueoCaja {
  id               String   @id @default(uuid())
  turnoId          String
  denominaciones   Json
  efectivoEsperado Decimal  @db.Decimal(10, 2)
  efectivoContado  Decimal  @db.Decimal(10, 2)
  diferencia       Decimal  @db.Decimal(10, 2)
  usuarioId        String
  createdAt        DateTime @default(now())

  turno            TurnoCaja @relation(fields: [turnoId], references: [id])

  @@index([turnoId, createdAt])
  @@map("arqueos_caja")
}
