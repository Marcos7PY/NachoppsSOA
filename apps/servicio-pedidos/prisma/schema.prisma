generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Pedido {
  id        String   @id @default(uuid())
  mesaId    String
  items     Json
  estado    String   @default("PENDIENTE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([mesaId])
  @@index([estado])
}
