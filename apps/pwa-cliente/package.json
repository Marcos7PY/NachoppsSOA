{
  "name": "@org/pwa-cliente",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "name": "pwa-cliente",
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "options": {
          "command": "vite build",
          "cwd": "apps/pwa-cliente"
        }
      },
      "serve": {
        "executor": "nx:run-commands",
        "options": {
          "command": "vite",
          "cwd": "apps/pwa-cliente"
        }
      },
      "preview": {
        "executor": "nx:run-commands",
        "options": {
          "command": "vite preview",
          "cwd": "apps/pwa-cliente"
        }
      }
    },
    "tags": [
      "frontend",
      "pwa"
    ]
  },
  "dependencies": {
    "lucide-react": "^1.16.0",
    "react-router-dom": "^7.15.1",
    "zustand": "^5.0.13"
  }
}
