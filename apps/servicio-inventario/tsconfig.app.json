{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "../../dist/apps/servicio-inventario",
    "types": [
      "node"
    ],
    "rootDir": "../../",
    "tsBuildInfoFile": "dist/tsconfig.app.tsbuildinfo",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "target": "es2021",
    "declaration": false,
    "declarationMap": false,
    "emitDeclarationOnly": false,
    "composite": false
  },
  "include": [
    "src/**/*.ts",
    "../../libs/resiliencia/**/*.ts",
    "../../libs/contracts/**/*.ts",
    "../../libs/shared-rabbitmq/**/*.ts",
    "../../libs/observabilidad/**/*.ts",
    "../../libs/shared-auth/**/*.ts"
  ],
  "exclude": []
}