{
  "name": "@org/servicio-cuentas-e2e",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "name": "servicio-cuentas-e2e",
    "implicitDependencies": [
      "servicio-cuentas"
    ],
    "targets": {
      "e2e": {
        "executor": "@nx/jest:jest",
        "outputs": [
          "{projectRoot}/test-output/jest/coverage"
        ],
        "options": {
          "jestConfig": "apps/servicio-cuentas-e2e/jest.config.cts",
          "passWithNoTests": true
        },
        "dependsOn": [
          "servicio-cuentas:build",
          "servicio-cuentas:serve"
        ]
      }
    }
  }
}
