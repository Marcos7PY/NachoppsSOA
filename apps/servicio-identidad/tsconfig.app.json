{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "../../dist/apps/servicio-identidad",
    "rootDir": "../../",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "types": ["node"],
    "tsBuildInfoFile": "dist/tsconfig.app.tsbuildinfo",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "target": "ES2021",
    "declaration": false,
    "declarationMap": false,
    "emitDeclarationOnly": false,
    "composite": false
  },
  "exclude": ["jest.config.ts", "src/**/*.spec.ts", "src/**/*.test.ts"],
  "include": ["src/**/*.ts", "../../libs/contracts/src/**/*.ts"],
  "references": [
    {
      "path": "../../libs/contracts/tsconfig.lib.json"
    },
    {
      "path": "../../libs/observabilidad/tsconfig.lib.json"
    },
    {
      "path": "../../libs/shared-rabbitmq"
    },
    {
      "path": "../../libs/shared-prisma/tsconfig.lib.json"
    }
  ]
}
