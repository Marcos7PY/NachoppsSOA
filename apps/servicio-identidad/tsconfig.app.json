{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "../../dist/apps/servicio-identidad",
    "rootDir": "../../",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "types": ["node"],
    "tsBuildInfoFile": "dist/tsconfig.app.tsbuildinfo",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "target": "ES2021",
    "declaration": false,
    "declarationMap": false,
    "emitDeclarationOnly": false,
    "composite": false
  },
  "exclude": ["jest.config.ts", "src/**/*.spec.ts", "src/**/*.test.ts"],
  "include": ["src/**/*.ts", "../../libs/contracts/src/**/*.ts"],
  "nx": {
    "sync": {
      "ignoredDependencies": [
        "@org/observabilidad",
        "@org/shared-rabbitmq",
        "contracts",
        "shared-prisma"
      ]
    }
  },
  "references": [
    {
      "path": "../../libs/shared-auth"
    },
    {
      "path": "../../libs/resiliencia/tsconfig.lib.json"
    }
  ]
}
