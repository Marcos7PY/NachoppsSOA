{
  "name": "@org/servicio-identidad",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "name": "servicio-identidad",
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "options": {
          "command": "tsc -p apps/servicio-identidad/tsconfig.app.json && npx tsc-alias -p apps/servicio-identidad/tsconfig.app.json && node -e \"const fs=require('fs'); if(fs.existsSync('apps/servicio-identidad/src/generated')) fs.cpSync('apps/servicio-identidad/src/generated', 'dist/apps/servicio-identidad/apps/servicio-identidad/src/generated', {recursive: true})\""
        },
        "configurations": {
          "production": {}
        }
      },
      "prune-lockfile": {
        "dependsOn": [
          "build"
        ],
        "cache": true,
        "executor": "@nx/js:prune-lockfile",
        "outputs": [
          "{workspaceRoot}/apps/servicio-identidad/dist/package.json",
          "{workspaceRoot}/apps/servicio-identidad/dist/package-lock.json"
        ],
        "options": {
          "buildTarget": "build"
        }
      },
      "copy-workspace-modules": {
        "dependsOn": [
          "build"
        ],
        "cache": true,
        "outputs": [
          "{workspaceRoot}/apps/servicio-identidad/dist/workspace_modules"
        ],
        "executor": "@nx/js:copy-workspace-modules",
        "options": {
          "buildTarget": "build"
        }
      },
      "prune": {
        "dependsOn": [
          "prune-lockfile",
          "copy-workspace-modules"
        ],
        "executor": "nx:noop"
      },
      "serve": {
        "executor": "nx:run-commands",
        "dependsOn": [
          "build"
        ],
        "options": {
          "command": "node dist/apps/servicio-identidad/apps/servicio-identidad/src/main.js"
        },
        "continuous": true
      }
    },
    "tags": [
      "backend",
      "service",
      "identidad"
    ]
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@org/shared-prisma": "*",
    "bcrypt": "^6.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/passport-jwt": "^4.0.1"
  }
}
