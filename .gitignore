# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
tmp
out-tsc

# Docker secrets (plan 2.3): nunca commitear el contenido real.
infra/secrets/*
!infra/secrets/README.md

# Limpieza de repo (plan 6.4 / T-20)
logs/
new-front/
# Artefactos deprecados sacados del control de versiones en T-20 (siguen en disco
# y en el historial de git; `git ls-files` ya no los lista).
docs-deprecated/
design_handoff_nachopps/

# Cache incremental de TypeScript: regenerable, nunca versionar (T-20)
*.tsbuildinfo

# Evidencia local de corridas y CI, no versionar (salvo el baseline consolidado).
# Se ignora el *contenido* del dir (no el dir en si) para que la excepcion del
# baseline funcione: git no re-incluye archivos bajo un dir excluido con `/`.
stress-tests/reports/*
!stress-tests/reports/BASELINE.md
.ci-logs/

# dependencies
node_modules

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

.nx/cache
.nx/workspace-data
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

.claude/worktrees
.claude/settings.local.json
.nx/polygraph
.nx/self-healing
vite.config.*.timestamp*
test-output

# Playwright (output de corridas e2e)
**/test-results/
**/playwright-report/
**/.playwright/

# Vite env locales (generados en build, no versionar)
**/.env.*.local

# Prisma clients generados por servicio
**/src/generated/prisma

.env
# SonarQube token local
infra/sonarqube/.sonar-token.local
