# ============================================================
# NachoPps Restobar — Variables de Entorno (template)
# Copiar a .env y reemplazar placeholders con valores reales.
# Los nombres aquí coinciden EXACTAMENTE con los que lee
# infra/docker-compose.prod.yml (interpolación ${VAR}).
# ============================================================

# ── Registro de imágenes ───────────────────────────────
REGISTRY=nachopps

# ── Base de Datos (Postgres, una por servicio) ─────────
DB_USER=nachopps
DB_PASS=change_me_a_strong_password          # OBLIGATORIO en prod (fail-fast)

# ── RabbitMQ ───────────────────────────────────────────
RABBITMQ_USER=nachopps
RABBITMQ_PASS=change_me_a_strong_password    # OBLIGATORIO en prod (fail-fast)

# ── JWT (firma de sesión) ──────────────────────────────
# Tokens de USUARIO en RS256 (asimétrico). Genera el par con:
#   node scripts/generate-jwt-keys.mjs
# Pega las PEM en una sola línea con "\n" escapados.
# La PRIVADA vive SOLO en servicio-identidad; la PÚBLICA va a todos + Kong.
JWT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----  # SOLO identidad, OBLIGATORIO en prod
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----      # todos los servicios, OBLIGATORIO en prod
# Access corto + refresh largo con rotación (plan 1.4).
JWT_EXPIRES_IN=15m                           # vida del access token
REFRESH_TOKEN_TTL_DAYS=7                      # vida del refresh token (cookie httpOnly)
# Tokens de SERVICIO (S2S interno, HS256). Secreto distinto al de usuario.
SERVICE_JWT_SECRET=change_me_a_long_random_secret  # OBLIGATORIO en prod

# ── Kong (API Gateway) ─────────────────────────────────
KONG_JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----  # == JWT_PUBLIC_KEY (RS256)
# CORS del gateway: secuencia YAML en línea con el/los dominio(s) https de la PWA.
KONG_CORS_ORIGINS=["https://app.tudominio.com"]    # OBLIGATORIO en prod
KONG_RATE_LIMIT_MINUTE=3000
KONG_RATE_LIMIT_HOUR=30000

# ── CORS a nivel de microservicio (defensa en profundidad) ──
# Coma-separado. Mismo dominio https de la PWA.
CORS_ORIGIN=https://app.tudominio.com        # OBLIGATORIO en prod

# ── Observabilidad ─────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
GRAFANA_PASS=change_me
# Webhook Slack para alertas de outbox FAILED (plan 3.3). Opcional; si se omite,
# la alerta solo se loguea. Las alertas de Prometheus van por Alertmanager.
SLACK_WEBHOOK_URL=
